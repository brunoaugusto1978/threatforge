# Copy this file to .env and fill the values. NEVER commit .env.

# Required: API key. Generate with: openssl rand -hex 32
API_KEY=change-this-key

# Database. Default for docker-compose. For local development, use sqlite:///./threatforge.db
DATABASE_URL=postgresql+psycopg2://threatforge:threatforge@db:5432/threatforge

# PostgreSQL password used by docker-compose
POSTGRES_PASSWORD=change-this-password

# Optional: abuse.ch Auth-Key for URLhaus (https://auth.abuse.ch)
ABUSECH_API_KEY=

# Optional: allowed CORS origins separated by commas. Empty means none.
CORS_ORIGINS=

# --- Auth / web interface ---
# Secret used to sign the session JWT. If empty, API_KEY is used. Generate a dedicated value:
#   openssl rand -hex 32
JWT_SECRET=
# Session duration in seconds. Default: 8h
JWT_TTL_SECONDS=28800
# true when serving over HTTPS. Recommended in production. For http://localhost: false
COOKIE_SECURE=false

# Initial platform operator. OPTIONAL for headless multi-tenant deployments.
# The default path is the "create operator" screen at /.
# If BOTH variables are defined, the operator is created on first startup.
# Leave them empty to create the operator through the UI.
BOOTSTRAP_OPERATOR_EMAIL=
BOOTSTRAP_OPERATOR_PASSWORD=

# Legacy single-tenant variables. Not used in the current multi-tenant flow.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- Invitations / links ---
# Base URL used to build invitation links. Dev: http://localhost:8000 ; production: HTTPS.
APP_BASE_URL=http://localhost:8000
# Invitation validity in hours. Default: 168 = 7 days
INVITE_TTL_HOURS=168

# --- Alerts / brand monitoring ---
# Minimum verdict required to alert: low | suspicious | malicious
ALERT_MIN_VERDICT=suspicious

# Telegram. Create a bot with @BotFather and get the chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Generic webhook. Slack/Discord/Teams/SIEM receive the alert JSON.
ALERT_WEBHOOK_URL=

# E-mail / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_STARTTLS=true

# --- Edition & Enterprise license activation ---------------------------------
# Community is the default. Enterprise is an overlay installed on top of the same
# database/schema (no migration). The variables below are consumed by the private
# threatforge-enterprise package; Community only records whether they are set.
THREATFORGE_EDITION=community
# THREATFORGE_ENTERPRISE_LICENSE_FILE=/run/secrets/threatforge-license.json
# THREATFORGE_ENTERPRISE_PUBLIC_KEY_FILE=/run/secrets/threatforge-license-public.pem
# THREATFORGE_ENTERPRISE_LICENSE_KEY_ID=cbg-prod-2026-01
# THREATFORGE_ENTERPRISE_INSTALLATION_ID=tf_inst_customer_x

# Public commercial contact shown in the 402 upgrade CTA (no personal data).
# THREATFORGE_ENTERPRISE_CONTACT_EMAIL=commercial@cbgsecurity.com.br
# THREATFORGE_ENTERPRISE_CONTACT_URL=https://cbgsecurity.com.br
