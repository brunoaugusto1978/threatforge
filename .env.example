# Copie para .env e preencha. NUNCA commite o .env.

# Obrigatório: chave da API (gere com: openssl rand -hex 32)
API_KEY=troque-esta-chave

# Banco (default do docker-compose; para dev local use sqlite:///./threatforge.db)
DATABASE_URL=postgresql+psycopg2://threatforge:threatforge@db:5432/threatforge

# Senha do PostgreSQL usada pelo docker-compose
POSTGRES_PASSWORD=troque-esta-senha

# Opcional: Auth-Key do abuse.ch para URLhaus (https://auth.abuse.ch)
ABUSECH_API_KEY=

# Opcional: origens CORS permitidas (separadas por vírgula). Vazio = nenhuma.
CORS_ORIGINS=

# --- Alertas (monitoramento de marca) ---
# Veredito mínimo para alertar: low | suspicious | malicious
ALERT_MIN_VERDICT=suspicious

# Telegram (crie um bot com @BotFather e pegue o chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook genérico — Slack/Discord/Teams/SIEM recebem o JSON do alerta
ALERT_WEBHOOK_URL=

# E-mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_STARTTLS=true
